# Supabase — get these from your Supabase project settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Supabase client-side (same values as above, exposed via Vite)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key

# Supabase service role — only needed for admin operations (server-side only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Lovable AI gateway — powers AI coach, journey generation, check-in validation
LOVABLE_API_KEY=your-lovable-api-key

# Anthropic Claude API — powers community post moderation (server-side only)
ANTHROPIC_API_KEY=sk-ant-...
